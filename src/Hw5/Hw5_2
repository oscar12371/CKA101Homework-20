package Hw5;

public class Hw5_2 {
	public static void main(String[] args) {
		int n[]=new int[10];
		double sum = 0;
		double avg = 0;
		for(int i =0;i<10;i++) {
			int r = 0;
			r = (int)(Math.random()*100)+1;	
			n[i]=r;
			System.out.print(r+" ");
			sum = sum + r ;
			
		}
		System.out.println();
		avg=sum/10;
		System.out.print(avg);
	}
}
