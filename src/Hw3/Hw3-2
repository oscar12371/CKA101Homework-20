package Hw3;

import java.util.Scanner;

public class Hw3_2 {
	public static void main(String[] args) {
		System.out.println("開始猜數字ㄅ");
		int a;
		int b;
		b = (int) (Math.random() * 100) + 1;
		Scanner sc = new Scanner(System.in);
		while (true) {
			System.out.println("請輸入：");
			if (sc.hasNextInt()) {
				a = sc.nextInt();

				if (a != b) {
					System.out.print("猜錯了，答案就是" + b);
				} else {
					System.out.print("恭喜你猜中了，答案就是" + b);
					break;
				}

			}

		}

	}
}
