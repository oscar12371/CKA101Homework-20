package Hw4;

public class Hw4_3 {
	public static void main(String[] args) {
		String[] aeiou = { "mercury", "venus", "earth", "mars", "jupiter", "saturn", "uranus", "neptune" };
		int count = 0;
		for (int i = 0; i < aeiou.length; i++) {
			char[] arr = aeiou[i].toCharArray(); // toCharArray 把字拆開

			for (int j = 0; j < arr.length; j++) {
				if (arr[j] == 'a' || arr[j] == 'e' || arr[j] == 'i' || arr[j] == 'o' || arr[j] == 'u')
					count++;
			}
		}
		System.out.print("總數" + count);
	}
}
